{
  "name": "pos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:app": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "git config core.hooksPath githooks"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc,css}": "biome format --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.3.0",
    "antd": "^6.4.3",
    "antd-style": "^4.1.0",
    "better-auth": "^1.6.16",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.8"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "better-sqlite3",
    "sharp",
    "sqlite3",
    "unrs-resolver"
  ]
}
